{
  "name": "@zillow-roi/backend-api",
  "version": "1.0.0",
  "description": "Express.js REST API for the Zillow ROI Analyzer",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "jest --runInBand",
    "test:coverage": "jest --runInBand --coverage",
    "migrate": "node db/migrate.js"
  },
  "dependencies": {
    "@zillow-roi/data-integration": "file:../data-integration",
    "@zillow-roi/types": "file:../packages/types",
    "bcryptjs": "2.4.3",
    "connect-pg-simple": "9.0.1",
    "express": "4.19.2",
    "express-rate-limit": "7.2.0",
    "express-session": "1.18.0",
    "helmet": "7.1.0",
    "joi": "17.12.2",
    "pg": "8.11.3",
    "uuid": "9.0.1"
  },
  "devDependencies": {
    "jest": "29.7.0",
    "supertest": "7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"]
  }
}
