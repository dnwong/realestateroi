# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Property Data Provider
# Options: rentcast | realtor | rapidapi-zillow
PROPERTY_PROVIDER=rentcast
PROPERTY_API_KEY=your_property_api_key_here

# Rental Data
RENTCAST_API_KEY=your_rentcast_api_key_here
RENTCAST_RELIABILITY_SCORE=0.8
PROPERTY_API_RELIABILITY_SCORE=0.6

# Cost of Living Provider
# Options: numbeo | teleport
COL_PROVIDER=teleport
COL_API_KEY=your_col_api_key_here

# Scraper Settings
SCRAPER_REQUEST_DELAY_MS=2000
