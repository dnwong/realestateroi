# Root .env.example — copy to .env and fill in values for local Docker Compose

# PostgreSQL
POSTGRES_PASSWORD=devpassword

# Redis
REDIS_PASSWORD=devpassword

# Session
SESSION_SECRET=change-this-to-a-random-32-char-string

# Property Data Provider (rentcast | realtor | rapidapi-zillow)
PROPERTY_PROVIDER=rentcast
PROPERTY_API_KEY=your_property_api_key_here

# Rental Data
RENTCAST_API_KEY=your_rentcast_api_key_here

# Cost of Living Provider (teleport | numbeo)
COL_PROVIDER=teleport
COL_API_KEY=
